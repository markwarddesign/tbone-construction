{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "tbone-construction/review-card",
    "version": "1.0.0",
    "title": "Review Card",
    "category": "tbone-construction",
    "description": "A single customer review card.",
    "textdomain": "tbone-construction",
    "parent": [ "tbone-construction/reviews-grid" ],
    "editorScript": "file:../../build/review-card/index.js",
    "render": "file:./render.php",
    "attributes": {
        "name":   { "type": "string", "default": "Customer Name" },
        "date":   { "type": "string", "default": "" },
        "rating": { "type": "number", "default": 5 },
        "text":   { "type": "string", "default": "Review text…" }
    },
    "supports": { "html": false, "inserter": false, "reusable": false }
}
