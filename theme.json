{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": false,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "1280px",
            "wideSize": "1536px"
        },
        "color": {
            "palette": [
                { "slug": "linen",       "color": "#faf8f5", "name": "Linen" },
                { "slug": "ink",         "color": "#1f2926", "name": "Ink" },
                { "slug": "rust",        "color": "#c25e24", "name": "Rust" },
                { "slug": "rust-dark",   "color": "#7a3b16", "name": "Rust Dark" },
                { "slug": "gold",        "color": "#eab308", "name": "Gold" },
                { "slug": "stone-100",   "color": "#f5f5f4", "name": "Stone 100" },
                { "slug": "stone-200",   "color": "#e7e5e4", "name": "Stone 200" },
                { "slug": "stone-600",   "color": "#57534e", "name": "Stone 600" },
                { "slug": "stone-700",   "color": "#44403c", "name": "Stone 700" },
                { "slug": "stone-800",   "color": "#292524", "name": "Stone 800" },
                { "slug": "stone-900",   "color": "#1c1917", "name": "Stone 900" }
            ],
            "custom": false,
            "customDuotone": false,
            "customGradient": false,
            "defaultDuotone": false,
            "defaultGradients": false,
            "defaultPalette": false
        },
        "typography": {
            "customFontSize": false,
            "defaultFontSizes": false,
            "fontFamilies": [
                {
                    "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
                    "slug": "sans",
                    "name": "Sans"
                },
                {
                    "fontFamily": "Georgia, 'Times New Roman', serif",
                    "slug": "serif",
                    "name": "Serif"
                }
            ]
        },
        "spacing": {
            "customSpacingSize": false,
            "defaultSpacingSizes": false
        }
    },
    "styles": {
        "color": {
            "background": "#faf8f5",
            "text": "#1c1917"
        },
        "typography": {
            "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
            "fontSize": "16px",
            "lineHeight": "1.6"
        },
        "spacing": {
            "blockGap": "0"
        }
    },
    "templateParts": [
        { "name": "header", "title": "Header", "area": "header" },
        { "name": "footer", "title": "Footer", "area": "footer" }
    ]
}
