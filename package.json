{
    "name": "tbone-construction",
    "version": "1.0.0",
    "scripts": {
        "build": "wp-scripts build",
        "start": "wp-scripts start",
        "build:css": "tailwindcss -i ./src/style.css -o ./assets/css/style.css --minify",
        "watch:css": "tailwindcss -i ./src/style.css -o ./assets/css/style.css --watch",
        "dev": "concurrently \"npm run start\" \"npm run watch:css\"",
        "lint:js": "wp-scripts lint-js",
        "lint:css": "wp-scripts lint-style"
    },
    "devDependencies": {
        "@wordpress/scripts": "^30.0.0",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.0.0",
        "tailwindcss": "^3.4.17"
    },
    "dependencies": {
        "lucide-react": "^0.468.0"
    }
}
